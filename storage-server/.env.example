# ─── KickCut – Storage Server Environment Variables ─────────────────────────
# Copy this file to .env and fill in the real values before starting the storage server.
# Never commit the actual .env — it's already in .gitignore.

# Full MongoDB connection string.
# The storage server is the only process that talks to the database directly —
# everything else goes through it over TCP.
# Format:  mongodb+srv://<user>:<password>@<cluster-host>/<db>?appName=<app>
# Get yours from: MongoDB Atlas → Connect → Drivers
MONGO_URI=mongodb+srv://YOUR_DB_USER:YOUR_DB_PASSWORD@cluster0.xxxx.mongodb.net/?appName=Cluster0

# TCP port this server listens on.
# Must match STORAGE_PORT in server/.env.
# Only bind to 127.0.0.1 (localhost) — this server is not meant to be reachable
# from outside the machine.
TCP_PORT=9000
