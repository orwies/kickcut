# ─── KickCut – Main Server Environment Variables ────────────────────────────
# Copy this file to .env and fill in the real values before starting the server.
# Never commit the actual .env — it's already in .gitignore.

# Port the HTTPS + WSS server listens on.
# 3443 works fine for local dev. If you change it, update the client too.
PORT=3443

# Secret key used to sign and verify JSON Web Tokens.
# Change this to a long random string before deploying — anyone who knows this
# value can forge tokens and log in as any user.
# Example: openssl rand -hex 64
JWT_SECRET=change_this_to_a_long_random_secret

# Address of the storage server (TCP).
# Leave as 127.0.0.1 — the storage server only listens on localhost by design.
STORAGE_HOST=127.0.0.1

# TCP port the storage server listens on. Must match TCP_PORT in storage-server/.env.
STORAGE_PORT=9000

# Directory where uploaded videos and thumbnail images are saved.
# Relative to server/, so ./uploads puts them in server/uploads/.
UPLOAD_DIR=./uploads

# Your Google Gemini API key — needed for the KickBot AI chat channel.
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
